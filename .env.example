# Asaf Gastro Web Yönetim — ortam değişkenleri örneği
# Bu dosyayı .env olarak kopyalayıp gerçek değerleri girin. .env ASLA commit edilmez.

# --- Ticimax Web Servis ---
# Her SOAP çağrısında UyeKodu olarak gider
TICIMAX_WS_KEY=
# Mağaza alan adı (servis .svc URL tabanı)
TICIMAX_BASE_URL=https://www.asafgastro.com

# --- UPS Kargo SMART ---
UPS_CUSTOMER_CODE=
UPS_USER_CODE=
UPS_USER_PASS=

# --- Supabase ---
SUPABASE_URL=https://twkryuvztnjlvlozuamv.supabase.co
# Renderer/public istemci için publishable (anon) key
SUPABASE_ANON_KEY=
# Yalnız main process service-role işlemleri için (gizli — renderer'a verilmez)
SUPABASE_SERVICE_KEY=
# Migrasyon/direct connection için DB şifresi (gizli)
SUPABASE_DB_PASSWORD=

# --- GitHub (electron-updater publish; yalnız geliştirme/CI) ---
GH_RELEASE_TOKEN=
